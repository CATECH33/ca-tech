{
  "buildCommand": "sh build.sh",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index",            "destination": "/",             "permanent": true },
    { "source": "/blog",             "destination": "/",             "permanent": true },
    { "source": "/blog/(.*)",        "destination": "/",             "permanent": true },
    { "source": "/diagnostic-ia",    "destination": "/contact",      "permanent": true },
    { "source": "/nos-realisations", "destination": "/realisations", "permanent": true },
    { "source": "/loic-ia",         "destination": "/loic",          "permanent": true },
    { "source": "/manager/(.*)", "missing": [{ "type": "host", "value": "manager.ca-tech.fr" }], "destination": "https://manager.ca-tech.fr/manager/$1", "permanent": false },
    { "source": "/manager",      "missing": [{ "type": "host", "value": "manager.ca-tech.fr" }], "destination": "https://manager.ca-tech.fr/manager",    "permanent": false },
    { "source": "/",             "has":     [{ "type": "host", "value": "manager.ca-tech.fr" }], "destination": "/manager",                               "permanent": false }
  ],
  "rewrites": [
    { "source": "/manager/assets/(.*)", "has": [{ "type": "host", "value": "manager.ca-tech.fr" }], "destination": "/manager/dist/assets/$1" },
    { "source": "/manager/(.*)",        "has": [{ "type": "host", "value": "manager.ca-tech.fr" }], "destination": "/manager/dist/index.html" }
  ]
}
