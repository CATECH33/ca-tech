# ─────────────────────────────────────────────────────────────────────────────
# CA-TECH — Variables de tracking (copier en .env et remplir les valeurs)
# Ces valeurs sont à insérer dans les constantes de index.html avant déploiement.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Tag Manager ────────────────────────────────────────────────────────
# Récupérer sur : tagmanager.google.com → Administration → Infos du conteneur
GTM_CONTAINER_ID=

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# Récupérer sur : analytics.google.com → Administration → Flux de données → ID de mesure
GA4_MEASUREMENT_ID=

# ── Google Ads — Conversion Tracking ─────────────────────────────────────────
# Récupérer sur : ads.google.com → Outils → Suivi des conversions → Détails
# GADS_CONVERSION_ID : partie "AW-XXXXXXXXXX" (identifiant du compte)
GADS_CONVERSION_ID=

# Labels de conversion (partie après "/" dans le tag de conversion Google Ads)
# Créer une conversion par événement dans Google Ads → Suivi des conversions
GADS_LABEL_FORM_SUBMIT=        # Événement : form_submit      — Conversion : Contact
GADS_LABEL_GENERATE_LEAD=      # Événement : generate_lead    — Conversion : Devis / Lead
GADS_LABEL_PHONE_CALL=         # Événement : phone_call       — Conversion : Appel téléphonique
GADS_LABEL_WHATSAPP_CLICK=     # Événement : whatsapp_click   — Conversion : WhatsApp
GADS_LABEL_BOOK_APPOINTMENT=   # Événement : book_appointment — Conversion : Prise de RDV

# ── EmailJS ───────────────────────────────────────────────────────────────────
# Récupérer sur : emailjs.com → Account → General / Email Services / Email Templates
EJS_PUBLIC_KEY=
EJS_SERVICE_ID=
EJS_TEMPLATE_CONTACT=
EJS_TEMPLATE_DEVIS=
